# === Serveur ===
PORT=3000
NODE_ENV=production
PUBLIC_URL=https://your-domain.com

# === Sécurité ===
# Générés automatiquement par install.sh
JWT_SECRET=change-me-32-random-chars
SESSION_SECRET=change-me-32-random-chars

# === Admin (bootstrap initial — modifiable après via panel) ===
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
# Hash bcrypt — généré par install.sh (ne pas mettre le mot de passe en clair)
ADMIN_PASSWORD_HASH=

# === Panel Web ===
WEBPANEL_ENABLED=true
ADMIN_PANEL_ENABLED=true

# === Publicités / SEO ===
ADSENSE_CLIENT=
GA_MEASUREMENT_ID=
SITE_NAME=Audio Grabber Fixer
SITE_DESCRIPTION=Télécharger les vidéos Facebook en MP4 HD et MP3 gratuitement

# === Rate limiting ===
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=60
DOWNLOAD_RATE_LIMIT_MAX=20

# === yt-dlp / ffmpeg ===
YTDLP_BIN=yt-dlp
FFMPEG_BIN=ffmpeg
DOWNLOAD_TIMEOUT_MS=300000
# Dossier temporaire côté serveur. Les fichiers sont supprimés après envoi au visiteur.
DOWNLOAD_TMP_DIR=./data/tmp-downloads

# === Cookies Facebook ===
# Chemin du fichier cookies.txt (format Netscape) utilisé par yt-dlp
# pour télécharger les vidéos privées / réservées aux connectés.
# Le panel admin gère l'import multi-format (Netscape, JSON, header string).
FB_COOKIES_FILE=./data/fb-cookies.txt
